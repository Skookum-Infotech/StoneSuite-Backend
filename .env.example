PORT=500
JWT_SECRET=your_secret_key_here
JWT_EXPIRES_IN=24h
JWT_REMEMBER_ME_EXPIRES_IN=720h
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ===================================
# PostgreSQL Database Configuration
# ===================================
# Set DB_HOST=localhost when running backend outside Docker
# Set DB_HOST=postgres when running backend inside Docker Compose
#
DB_HOST=localhost
DB_PORT=5432
DB_USER=stonesuite
DB_PASSWORD=stonesuite_secret
DB_NAME=stonesuite
DB_SSLMODE=disable

# ===================================
# Microsoft Entra ID (Azure AD) OAuth
# ===================================
# To get these values:
# 1. Go to https://portal.azure.com
# 2. Create an App Registration
# 3. Copy the Application (client) ID
# 4. Create a Client Secret under Certificates & secrets
# 5. Add Redirect URI: http://localhost:8080/api/auth/entra/callback (for dev)
#
ENTRA_ID_CLIENT_ID=your-entra-id-client-id
ENTRA_ID_CLIENT_SECRET=your-entra-id-client-secret
ENTRA_ID_REDIRECT_URI=http://localhost:8080/api/auth/entra/callback

# ===================================
# AWS Cognito OAuth
# ===================================
# To get these values:
# 1. Go to https://console.aws.amazon.com/cognito
# 2. Create or select a User Pool
# 3. Go to App integration > App client settings
# 4. Get the Client ID and Client Secret
# 5. Set Allowed callback URLs: http://localhost:8080/api/auth/cognito/callback (for dev)
# 6. Domain is found under App integration > Domain name
#
# Format: your-domain.auth.region.amazoncognito.com (without the https://)
#
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_CLIENT_SECRET=your-cognito-client-secret
COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:8080/api/auth/cognito/callback

# ===================================
# Email Configuration (SMTP)
# ===================================
# For Gmail:
#   - Enable 2-factor authentication
#   - Generate App Password: https://myaccount.google.com/apppasswords
#   - SMTP_HOST=smtp.gmail.com
#   - SMTP_PORT=587
#   - SENDER_EMAIL=your-email@gmail.com
#   - SENDER_PASSWORD=your-app-password
#
# For other email providers, update accordingly
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password-or-email-password

# ===================================
# Cloudflare R2 (record attachments)
# ===================================
# Create an R2 bucket at https://dash.cloudflare.com → R2 Object Storage.
# Then create an API token with "Object Read & Write" permissions.
#
# R2_ACCOUNT_ID   : found in Cloudflare Dashboard → right sidebar "Account ID"
# R2_BUCKET       : the bucket name you created (e.g. stonesuite-attachments)
# R2_ACCESS_KEY_ID     : R2 API token access key
# R2_SECRET_ACCESS_KEY : R2 API token secret key
#
# Leave all four blank (or omit) to disable attachments during local dev.
# The binary will start normally; presign/download endpoints return 503.
#
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ===================================
# Observability (all optional)
# ===================================
# SENTRY_DSN    : enable error/panic reporting to Sentry (free tier: 5k/mo).
#                 Leave blank to disable — middleware.Recover then only logs.
# METRICS_TOKEN : when set, /api/metrics requires `Authorization: Bearer <token>`.
#                 Leave blank to expose Prometheus metrics without auth (dev).
# AXIOM_TOKEN   : Axiom API token (free tier ~500GB/mo). When set together with
# AXIOM_DATASET : the dataset name, structured logs are shipped to Axiom in
#                 addition to stdout — no shipper VM, scale-to-zero stays intact.
#                 Leave either blank to log to stdout only (`fly logs`).
#
# Health endpoints (no config needed):
#   GET /api/healthz — liveness (no DB)
#   GET /api/readyz  — readiness (pings control-plane DB)
#   GET /api/metrics — Prometheus scrape target
#
SENTRY_DSN=
METRICS_TOKEN=
AXIOM_TOKEN=
AXIOM_DATASET=

# ===================================
# AI Assistant (RAG) — see docs/ai-assistant.md
# ===================================
# Both embedding and chat are self-hosted via Ollama (ADR-001) — no
# third-party LLM account, API key, or quota at all.
#
# Embedder is pinned (snowflake-arctic-embed:m, 768-dim) — do not change
# AI_EMBED_MODEL/AI_EMBED_DIM without a re-index plan (different models
# produce incompatible vector spaces even at the same dimension — see
# docs/ai-assistant.md "Forcing a full reindex").
#
# OLLAMA_BASE_URL : the self-hosted box serving both embeddings and chat.
#                   Local dev: http://localhost:11434
#                     (`ollama pull snowflake-arctic-embed:m && ollama pull
#                     llama3.2:1b` on your machine).
#                   Prod (Fly): http://stonesuite-ollama.internal:11434 — see
#                     ollama/ (Dockerfile + fly.toml) for the deployed box.
# AI_CHAT_MODEL   : an Ollama model tag (e.g. llama3.2:1b) — must already be
#                   pulled on the Ollama box (see ollama/entrypoint.sh).
#
# All optional — the assistant no-ops (empty retrieval / errors on ask) when
# unconfigured; nothing else in the app depends on these.
#
# FLY_OLLAMA_API_TOKEN / FLY_OLLAMA_APP_NAME : prod only. The Ollama box has no
# reliable autostart of its own (Fly Proxy's flycast autostart was verified
# unreliable for this deployment), so this backend explicitly starts it on its
# own boot and stops it on its own graceful shutdown via Fly's Machines API —
# ties the embedder's uptime to this process's, not left running 24/7. Token
# must be scoped to just the Ollama app (`fly tokens create deploy -a
# stonesuite-ollama`). Leave unset for local dev or an always-on embedder box.
#
AI_EMBED_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
AI_CHAT_MODEL=llama3.2:1b
AI_EMBED_MODEL=snowflake-arctic-embed:m
AI_EMBED_DIM=768
FLY_OLLAMA_API_TOKEN=
FLY_OLLAMA_APP_NAME=stonesuite-ollama
